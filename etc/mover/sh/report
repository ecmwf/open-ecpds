#!/bin/sh

#
# File report
#
# Purpose: Helper for nmap and mtr (OpenECPDS)
#
# (c) Copyright ECMWF 2013-2026 - Laurent Gougeon (syi@ecmwf.int)
#

##########################
## Load configuration file
##########################
if [ -f "/usr/local/ecpds/mover/sh/ecenv" ]; then
  source /usr/local/ecpds/mover/sh/ecenv
else
  # Started from Eclipse/development - resolve binaries without relying on PATH
  # (JVM-spawned processes inherit a minimal environment that may not include
  # Homebrew or other non-standard locations)
  find_bin() {
    for dir in /opt/homebrew/bin /opt/homebrew/sbin /usr/local/bin /usr/local/sbin \
               /usr/bin /usr/sbin /bin /sbin; do
      [ -x "$dir/$1" ] && echo "$dir/$1" && return 0
    done
    return 1
  }
  echo=echo
  hostname=hostname
  nmap=$(find_bin nmap)  || { $echo "Binary 'nmap' not found on `$hostname` (please install)"; exit 0; }
  mtr=$(find_bin mtr)    || { $echo "Binary 'mtr' not found on `$hostname` (please install)"; exit 0; }
  ping=$(find_bin ping)  || { $echo "Binary 'ping' not found on `$hostname` (please install)"; exit 0; }
  grep=$(find_bin grep)  || { $echo "Binary 'grep' not found on `$hostname` (please install)"; exit 0; }
fi

########################
## Deal with the request
########################
case $# in
 0) $echo "DataMover Report for `$hostname`"
    $echo
    exit 0
 ;;
 2) $echo "Report generated from `$hostname`"
    $echo
    $nmap -Pn -p $2 $1
    $echo
    $mtr -c 10 -P $2 $1 --report-wide --aslookup
    exit 0
 ;;
 3) source=$($ping -c 1 $3 | $grep -Eo '([0-9]{1,3}\.){3}[0-9]{1,3}' | tail -1)
    $echo "Report generated from `$hostname`"
    $echo
    $nmap -S $source -Pn -p $2 $1
    $echo
    $mtr --address $source -c 10 -P $2 $1 --report-wide --aslookup
    exit 0
 ;;
 *) $echo "format: report | report {host} {port} {listenAddress}"
    exit -1
 ;;
esac
